#include <stdio.h>

int main() {
    float m1, m2, m3, m4, m5, total, per;

    printf("Enter marks of 5 subjects: ");
    scanf("%f %f %f %f %f", &m1, &m2, &m3, &m4, &m5);

    // Calculate total and percentage
    total = m1 + m2 + m3 + m4 + m5;
    per = total / 5;

    printf("Total Marks = %.2f\n", total);
    printf("Percentage = %.2f\n", per);

    // Grade using if-else
    if (per >= 90) {
        printf("Grade: A\n");
    }
    else if (per >= 75) {
        printf("Grade: B\n");
    }
    else if (per >= 60) {
        printf("Grade: C\n");
    }
    else if (per >= 40) {
        printf("Grade: D\n");
    }
    else {
        printf("Grade: Fail\n");
    }

    return 0;
}
